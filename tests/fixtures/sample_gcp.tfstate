{
  "version": 4,
  "terraform_version": "1.8.1",
  "serial": 8,
  "lineage": "gcp123abc",
  "format_version": "4",
  "resources": [
    {
      "mode": "managed",
      "type": "google_compute_network",
      "name": "main",
      "provider": "provider[\"registry.terraform.io/hashicorp/google\"]",
      "instances": [{
        "provider_name": "registry.terraform.io/hashicorp/google",
        "dependencies": [],
        "attributes": {
          "id": "projects/my-gcp-project/global/networks/main-network",
          "name": "main-network",
          "auto_create_subnetworks": false,
          "project": "my-gcp-project",
          "labels": {"environment": "prod"}
        }
      }]
    },
    {
      "mode": "managed",
      "type": "google_compute_subnetwork",
      "name": "app",
      "provider": "provider[\"registry.terraform.io/hashicorp/google\"]",
      "instances": [{
        "provider_name": "registry.terraform.io/hashicorp/google",
        "dependencies": ["google_compute_network.main"],
        "attributes": {
          "id": "projects/my-gcp-project/regions/us-central1/subnetworks/app-subnet",
          "name": "app-subnet",
          "ip_cidr_range": "10.0.1.0/24",
          "region": "us-central1",
          "network": "main-network",
          "project": "my-gcp-project",
          "private_ip_google_access": true
        }
      }]
    },
    {
      "mode": "managed",
      "type": "google_compute_firewall",
      "name": "app",
      "provider": "provider[\"registry.terraform.io/hashicorp/google\"]",
      "instances": [{
        "provider_name": "registry.terraform.io/hashicorp/google",
        "dependencies": ["google_compute_network.main"],
        "attributes": {
          "id": "projects/my-gcp-project/global/firewalls/app-firewall",
          "name": "app-firewall",
          "network": "main-network",
          "project": "my-gcp-project",
          "allow": [
            {"protocol": "tcp", "ports": ["443"]},
            {"protocol": "tcp", "ports": ["80"]}
          ],
          "source_ranges": ["0.0.0.0/0"],
          "direction": "INGRESS"
        }
      }]
    },
    {
      "mode": "managed",
      "type": "google_compute_instance",
      "name": "app",
      "provider": "provider[\"registry.terraform.io/hashicorp/google\"]",
      "instances": [{
        "provider_name": "registry.terraform.io/hashicorp/google",
        "dependencies": ["google_compute_subnetwork.app", "google_compute_firewall.app"],
        "attributes": {
          "id": "projects/my-gcp-project/zones/us-central1-a/instances/app-server",
          "name": "app-server",
          "machine_type": "e2-medium",
          "zone": "us-central1-a",
          "project": "my-gcp-project",
          "labels": {"environment": "prod", "app": "web-api"},
          "tags": {"items": ["web-server"]}
        }
      }]
    },
    {
      "mode": "managed",
      "type": "google_storage_bucket",
      "name": "artifacts",
      "provider": "provider[\"registry.terraform.io/hashicorp/google\"]",
      "instances": [{
        "provider_name": "registry.terraform.io/hashicorp/google",
        "dependencies": [],
        "attributes": {
          "id": "my-gcp-artifacts-bucket",
          "name": "my-gcp-artifacts-bucket",
          "location": "US",
          "project": "my-gcp-project",
          "uniform_bucket_level_access": true,
          "labels": {"purpose": "artifacts"}
        }
      }]
    },
    {
      "mode": "managed",
      "type": "google_service_account",
      "name": "app",
      "provider": "provider[\"registry.terraform.io/hashicorp/google\"]",
      "instances": [{
        "provider_name": "registry.terraform.io/hashicorp/google",
        "dependencies": [],
        "attributes": {
          "id": "projects/my-gcp-project/serviceAccounts/app-service-account@my-gcp-project.iam.gserviceaccount.com",
          "account_id": "app-service-account",
          "display_name": "App Service Account",
          "email": "app-service-account@my-gcp-project.iam.gserviceaccount.com",
          "project": "my-gcp-project"
        }
      }]
    }
  ]
}
